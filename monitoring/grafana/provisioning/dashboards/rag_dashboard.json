{
  "uid": "rag-backend-overview",
  "title": "RAG Backend Overview",
  "tags": [
    "rag",
    "backend"
  ],
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request Rate (req/s by endpoint)",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (endpoint) (rate(rag_request_duration_seconds_count[5m]))",
          "legendFormat": "{{endpoint}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "P95 Request Latency by Endpoint",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (endpoint, le) (rate(rag_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{endpoint}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Pipeline Stage Avg Latency",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "rate(rag_pipeline_stage_seconds_sum[5m]) / rate(rag_pipeline_stage_seconds_count[5m])",
          "legendFormat": "{{stage}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Faithfulness Score",
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "rag_faithfulness_score",
          "legendFormat": "faithfulness"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.5
              },
              {
                "color": "green",
                "value": 0.7
              }
            ]
          },
          "custom": {
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Hallucination Rate",
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "rag_hallucination_rate",
          "legendFormat": "hallucination rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.2
              },
              {
                "color": "red",
                "value": 0.4
              }
            ]
          },
          "custom": {
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Cache Hit Rate",
      "gridPos": {
        "x": 12,
        "y": 16,
        "w": 6,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "rate(rag_cache_hits_total[5m]) / (rate(rag_cache_hits_total[5m]) + rate(rag_cache_misses_total[5m]))",
          "legendFormat": "hit rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.3
              },
              {
                "color": "green",
                "value": 0.6
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Documents & Chunks",
      "gridPos": {
        "x": 18,
        "y": 16,
        "w": 6,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "rag_documents_total",
          "legendFormat": "Documents"
        },
        {
          "expr": "rag_chunks_total",
          "legendFormat": "Chunks"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Error Rate by Type",
      "gridPos": {
        "x": 0,
        "y": 24,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (error_type) (rate(rag_errors_total[5m]))",
          "legendFormat": "{{error_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "lineWidth": 2
          }
        }
      }
    }
  ]
}